# Port for the backend API server
PORT=3000

# Secret key for signing JWT tokens
JWT_SECRET=yoursecretjwtkey

# Allowed origins for CORS (e.g., http://localhost:3001)
CORS_ORIGIN=*

# Default administrator credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Secret for encrypting sensitive data
ENCRYPTION_SECRET=yoursecretencryptionkey

# The public domain for the API (e.g., api.your-domain.com)
# This is used for the self-configuring reverse proxy.
API_DOMAIN=api.your-domain.com

# Your email address for Let's Encrypt notifications
LETSENCRYPT_EMAIL=your-email@example.com
